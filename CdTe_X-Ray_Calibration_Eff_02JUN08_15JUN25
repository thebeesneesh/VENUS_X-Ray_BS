# Function to read the value of the Live Time, total # lines, return channels, counts
def ReadData(name):
    f=open(name, 'r')
    nlines=0
    while f.readline(): nlines+=1
    f.seek(0)
    for i in range(nlines):
        line=f.readline().split()
        if (line[0]=='<<DATA>>'):
            Dlocation=i
            nDlines=nlines-1-Dlocation-1
            break

    D=zeros(nDlines, dtype=float)
    CH=arrayrange(nDlines)
    for i in range(nDlines):
        Ds=f.readline().split()
        D[i]=int(Ds[0])
    f.close()

    return(CH, D, nDlines)

