# LEAST-SQUARES FIRST ORDER FIT
def LeastSquares(x,y):
    # Least-Squares Fit
    n=len(x)
    xsum=sum(x, axis=0)
    ysum=sum(y, axis=0)
    xsqsum=sum(x*x, axis=0)
    ysqsum=sum(y*y,axis=0)
    xysum=sum(x*y, axis=0)
    xsumsq=xsum*xsum
    ysumsq=ysum*ysum
    # y=a+bx
    a=1.0*(ysum*xsqsum-xsum*xysum)/(n*xsqsum-xsumsq)
    b=1.0*(n*xysum-xsum*ysum)/(1.0*(n*xsqsum-xsumsq))

    chi_squared=0.
    # Chi-Squared Statistic
    for i in range(n):
        sigma_squared=y[i]                                 # For Statistical Uncertainties (Counting Experiments)
        chi_squared=chi_squared+(1/sigma_squared)*(y[i]-a-b*x[i])**2
        
    
    return(a,b, chi_squared)

