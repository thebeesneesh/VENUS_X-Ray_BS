# Account for NaI efficiency with varying energy
def eff(nRowsColumns,EndPointEnergy):
    EndPointEnergy=float(EndPointEnergy)
    nRowsColumns=float(nRowsColumns)

    #----------------------------------------------------------
    # SCINILLATOR EFFICIENCY: Probability that a photon will be completely absorbed.

    # 3x3in from 1960 Nuclear Data Tables
    Energy_Val=array((0., 100., 200., 300., 400., 500., 600., 700., 800., 900., 1000., 1100., 1200., 1300., 1400., 1500., 1600., 1700., 1800., 1900., 2000., 2100., 2200., 2300., 2400., 2500., 2600.), Float)
    Peak_to_Tot_Val=array((1.0, 0.99, 0.92, 0.83, 0.735, 0.65, 0.59, 0.53, 0.49, 0.45, 0.42, 0.38, 0.37, 0.335, 0.32, 0.305, 0.295, 0.280, 0.275, 0.270, 0.260, 0.255, 0.245, 0.235, 0.230, 0.220, 0.215), Float)
    
    # 09/11/07: from experimental data, for source at edge of detector table w/o lead
    Energy_Val_exp=array((0.0, 59.5, 569.7, 661.7, 1063.7, 1173.2), Float)
    Peak_to_Tot_Val_exp=array((1.0, 0.76686, 0.381, 0.3691901, 0.185285, 0.181), Float)
    
    step=float(EndPointEnergy/nRowsColumns)
    E=arrayrange(0,EndPointEnergy,step, Float)              # Empty array for Energy values of Peak-to-Totals from fit
    Peak_To_Tot=zeros(len(E), 'd')                          # Empty array for Peak-to-Total values from fit
    
    # Call Least-Squares 3rd Order Polynomial Fit for Scintillator Efficiency
    (a,b,c,d)=LeastSquaresPoly3(Energy_Val,Peak_to_Tot_Val)

    #a=0.80                                                   # Coefficients to match experimental data to shape of published data
    #b=-0.00089
    #c=3.58E-07
    #d=-4.85E-11


    #----------------------------------------------------------
    # TOTAL ABSOLUTE EFFICIENCY: Probability that a photon will be detected at all.

    # 3x3in Total Absolute Efficiency Values from 1960 Nuclear Data Tables
    Energy_Abs_Eff=array((0,100, 200, 300, 400, 500, 600, 700, 800, 900, 1000, 1100, 1200, 1300, 1400, 1500, 1600, 1700, 1800, 1900, 2000), Float)
    Abs_Eff_Values=(1/.009)*array((.009, .009, .0084, .0078, .0072, .0068, .0064, .0062, .0060, .0058, .0056, .0055, .0054, .0052, .0051, .0050, .0049, .00485, .0048, .00475, .0047), Float)
    Abs_Eff=zeros(len(E), 'd')                              # Empty array for Absolute Efficiency values 
    
    # Call Least-Squares 3rd Order Polynomial Fit for Scintillator Efficiency
    (a_Abs_Eff, b_Abs_Eff, c_Abs_Eff, d_Abs_Eff)=LeastSquaresPoly3(Energy_Abs_Eff, Abs_Eff_Values)
    
    #----------------------------------------------------------

    for i in range(0, len(E)):
        Peak_To_Tot[i]=a+b*E[i]+c*E[i]*E[i]+d*E[i]*E[i]*E[i]
        Abs_Eff[i]=a_Abs_Eff+b_Abs_Eff*E[i]+c_Abs_Eff*E[i]*E[i]+d_Abs_Eff*E[i]*E[i]*E[i]
        if Peak_To_Tot[i]>1:
            Peak_To_Tot[i]=1
        if Abs_Eff[i]>1:
            Abs_Eff[i]=1
      
    clf()
    plot(E,Peak_To_Tot, 'b',Energy_Val, Peak_to_Tot_Val, 'r', lw=2)
    
    xlabel('Energy (keV)')
    ylabel('P/T')
    xlim(0,max(E))
    ylim(min(Peak_To_Tot),1)
    legend(('Fit', 'Published Values'))
    title('Peak-to-Total Fits')
   
    #----------------------------------------------------------

    return(E, Peak_To_Tot, Abs_Eff)


