# Splint Code by Damon Todd
def splint(x,y,y2,X):
  N=len(y); h=x[2]-x[1];
  if(X<x[0]): X=x[0]    # Questionable solution method
  if(X>x[N-1]): X=x[N-1]  # Questionable solution method
  for i in range(1,N):
    if(X<=x[i]):
     l1=X-x[i-1]; l2=x[i]-X
     return ((y2[i]*pow(l1,3)+y2[i-1]*pow(l2,3))/(6.0*h) + (y[i]/h-y2[i]*h/6.0)*l1+(y[i-1]/h-y2[i-1]*h/6.0)*l2)
