# LEAST-SQUARES SECOND ORDER FIT

def LeastSquaresPoly(x,y):
    # Least-Squares Second Order Polynomial Fit
    n=len(x)
  
    xsum=sum(x, axis=0)
    ysum=sum(y, axis=0)
    
    x2sum=sum(x*x, axis=0)
    y2sum=sum(y*y,axis=0)
    x3sum=sum(1.0*x*x*x, axis=0)
    
    x4sum=sum(1.0*x*x*x*x, axis=0)
    #print xsum, ysum, x2sum, x3sum, x4sum 
    xysum=sum(x*y, axis=0)
    x2ysum=sum(x*x*y, axis=0)
    
    xsumsq=xsum*xsum
    ysumsq=ysum*ysum
    # y=a+bx+cx^2
    delta=1.0*n*(x2sum*x4sum-x3sum*x3sum)-xsum*(xsum*x4sum-x3sum*x2sum)+x2sum*(xsum*x3sum-x2sum*x2sum)
    a=(1/delta)*(ysum*(x2sum*x4sum-x3sum*x3sum)-xsum*(xysum*x4sum-x3sum*x2ysum)+x2sum*(xysum*x3sum-x2sum*x2ysum))
    b=(1/delta)*(n*(xysum*x4sum-x3sum*x2ysum)-ysum*(xsum*x4sum-x3sum*x2sum)+x2sum*(xsum*x2ysum-xysum*x2sum))
    c=(1/delta)*(n*(x2sum*x2ysum-xysum*x3sum)-xsum*(xsum*x2ysum-xysum*x2sum)+ysum*(xsum*x3sum-x2sum*x2sum))
   

    return(a,b,c)
