# Function to smooth out data by averaging certain number of points
def smoothdata(nDlines, D, CH, Epeaks, subtractStart1, subtractEnd1, subtractStart2, subtractEnd2):
    x=int(nDlines)

#
    Nch_o=nDlines                                               # number of original channels
    Nch_f=500                                                   # number of new channels
    dch=float(Nch_o)/float(Nch_f)                               # ratio of old # channels to new # channels
    P_ave=5.2
    W_ave=3.2
    width=int(ceil(3.2))
    AvgD=zeros(Nch_f, 'd')
    AvgCH=zeros(Nch_f, dtype=int)
    
    for i in range(Nch_f):
        sum=0
        div=0
        CH=i*dch
        ich=int(CH)
        for j in range(ich-width-1, ich+width+2):
            dd=abs(j-CH)/W_ave
            if (j>=0 and j<Nch_o and dd<1.0):
                t_div=(1-dd)*P_ave
                sum=sum+t_div*D[j]
                div=div+t_div
            for q in range(len(Epeaks)):
               if int(subtractStart1[q])==j:
                   subtractStart1[q]=i
               if int(subtractEnd1[q])==j:
                   subtractEnd1[q]=i
               if int(subtractStart2[q])==j:
                   subtractStart2[q]=i
               if int(subtractEnd2[q])==j:
                   subtractEnd2[q]=i
        if div>0.0: AvgD[i]=sum/div
        AvgCH[i]=int(i)

# Removed (beginrange, midrange, endrange, endrangetwo,) from list of return values
    return(AvgCH, AvgD, Nch_f, subtractStart1, subtractEnd1, subtractStart2, subtractEnd2)
