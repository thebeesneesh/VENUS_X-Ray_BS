def LeastSquaresPoly3(x,y):
    # Least-Squares 3rd order Polynomial Fit
    n=len(x)
    
    xsum=sum(x, axis=0)
    ysum=sum(y, axis=0)
    
    x2sum=sum(x*x, axis=0)
    y2sum=sum(y*y,axis=0)
    x3sum=sum(1.0*x*x*x, axis=0)
    x4sum=sum(1.0*x*x*x*x, axis=0)
    x5sum=sum(1.0*x*x*x*x*x, axis=0)
    x6sum=sum(1.0*x*x*x*x*x*x, axis=0)
    
    xysum=sum(x*y, axis=0)
    x2ysum=sum(x*x*y, axis=0)
    x3ysum=sum(x*x*x*y, axis=0)
    
    xsumsq=xsum*xsum
    ysumsq=ysum*ysum

    # y=a+bx+cx^2+dx^3
    det=1.0*determinant(array([[n, xsum, x2sum, x3sum],[xsum, x2sum, x3sum, x4sum],[x2sum, x3sum, x4sum, x5sum],[x3sum, x4sum, x5sum, x6sum]]))
    a=(1/det)*determinant(array([[ysum, xsum, x2sum, x3sum],[xysum, x2sum, x3sum, x4sum],[x2ysum, x3sum, x4sum, x5sum],[x3ysum, x4sum, x5sum, x6sum]]))
    b=(1/det)*determinant(array([[n, ysum, x2sum, x3sum],[xsum, xysum, x3sum, x4sum],[x2sum, x2ysum, x4sum, x5sum],[x3sum, x3ysum, x5sum, x6sum]]))
    c=(1/det)*determinant(array([[n, xsum, ysum, x3sum],[xsum, x2sum, xysum, x4sum],[x2sum, x3sum, x2ysum, x5sum],[x3sum, x4sum, x3ysum, x6sum]]))
    d=(1/det)*determinant(array([[n,xsum,x2sum,ysum],[xsum, x2sum, x3sum, xysum],[x2sum, x3sum, x4sum, x2ysum],[x3sum, x4sum, x5sum, x3ysum]]))

    

    return(a,b,c,d)

